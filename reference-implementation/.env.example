# Copy this file to .env and fill in the keys for the backends you want to use.
# You only need the key for whichever --backend you actually run.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# Ollama runs locally; no API key needed, just a running `ollama serve` instance.
OLLAMA_HOST=http://localhost:11434
